---
import { existsSync } from 'node:fs';
import { join } from 'node:path';
import FAQ from '@components/FAQ.astro';
import TestimonialCard from '@components/TestimonialCard.astro';
import DemoLayout from '@layouts/DemoLayout.astro';
import { getDemoBySlug } from '@data/demos';
import '@styles/themes/autoprime.css';

const demo = getDemoBySlug('autoprime')!;
const assetBase = '/assets/demos/autoprime';
const assetDir = join(process.cwd(), 'public', 'assets', 'demos', 'autoprime');
const getAutoAsset = (fileName: string) => ({
  fileName,
  src: `${assetBase}/${fileName}`,
  exists: existsSync(join(assetDir, fileName)),
});

const whatsappBase = 'https://wa.me/56912345678';
const quoteMessage = encodeURIComponent(
  'Hola AutoPrime, quiero cotizar un servicio automotriz. Mi vehículo es:'
);
const whatsappHref = `${whatsappBase}?text=${quoteMessage}`;

const assets = {
  hero: getAutoAsset('hero-taller-mecanico.webp'),
  scanner: getAutoAsset('diagnostico-scanner.webp'),
  brakes: getAutoAsset('mantencion-frenos.webp'),
  oil: getAutoAsset('cambio-aceite.webp'),
  detailing: getAutoAsset('detailing-auto.webp'),
  beforeAfter: getAutoAsset('antes-despues-detailing.webp'),
  workshop: getAutoAsset('taller-profesional.webp'),
  mechanic: getAutoAsset('mecanico-trabajando.webp'),
};

const quickStats = [
  { label: 'Diagnóstico', value: 'Scanner y pauta' },
  { label: 'Mantención', value: 'Por kilometraje' },
  { label: 'Detailing', value: 'Interior / exterior' },
  { label: 'Agenda', value: 'Respuesta rápida' },
];

const services = [
  {
    number: '01',
    title: 'Mantención preventiva',
    tag: 'Kilometraje',
    description:
      'Aceite, filtros, niveles, luces y revisión general según estado del vehículo.',
    asset: assets.oil,
    alt: 'Cambio de aceite y filtros en taller automotriz',
  },
  {
    number: '02',
    title: 'Scanner automotriz',
    tag: 'Diagnóstico',
    description:
      'Lectura de códigos, síntomas reportados y recomendaciones priorizadas por urgencia.',
    asset: assets.scanner,
    alt: 'Diagnóstico scanner conectado a un vehículo',
  },
  {
    number: '03',
    title: 'Frenos y suspensión',
    tag: 'Seguridad',
    description:
      'Revisión de pastillas, discos, amortiguadores, ruidos y desgaste visible.',
    asset: assets.brakes,
    alt: 'Mantención de frenos y suspensión de automóvil',
  },
  {
    number: '04',
    title: 'Cambio de aceite y filtros',
    tag: 'Rápido',
    description:
      'Servicio directo con insumos informados y checklist básico de puntos críticos.',
    asset: assets.oil,
    alt: 'Técnico realizando cambio de aceite de motor',
  },
  {
    number: '05',
    title: 'Detailing interior/exterior',
    tag: 'Detalle',
    description:
      'Lavado técnico, descontaminado, limpieza interior y protección según necesidad.',
    asset: assets.detailing,
    alt: 'Detailing exterior de auto en taller limpio',
  },
  {
    number: '06',
    title: 'Pre-revisión técnica',
    tag: 'Checklist',
    description:
      'Revisión preventiva de luces, frenos, neumáticos, fluidos y observaciones visibles.',
    asset: assets.mechanic,
    alt: 'Mecánico revisando vehículo antes de revisión técnica',
  },
];

const processSteps = [
  {
    title: 'Recepción del vehículo',
    text: 'Registramos motivo de visita, kilometraje, síntomas y prioridad del cliente.',
  },
  {
    title: 'Evaluación técnica',
    text: 'Revisamos puntos críticos, scanner si corresponde y evidencia visual disponible.',
  },
  {
    title: 'Cotización clara',
    text: 'Informamos trabajos sugeridos, repuestos y aprobacion antes de ejecutar.',
  },
  {
    title: 'Ejecucion del servicio',
    text: 'Realizamos la mantención o reparación acordada con orden de trabajo.',
  },
  {
    title: 'Entrega y recomendaciones',
    text: 'Explicamos lo realizado, próximos cuidados y alertas para revisar a futuro.',
  },
];

const trustItems = [
  'Presupuesto antes de ejecutar',
  'Repuestos informados al cliente',
  'Comunicación por WhatsApp',
  'Garantía de servicio realizado',
  'Registro fotográfico opcional',
  'Checklist de entrega',
];

const vehicleTypes = ['Autos particulares', 'SUV', 'Camionetas', 'Flotas pequeñas'];
---

<DemoLayout
  title={demo.seoTitle}
  description={demo.seoDescription}
  businessName={demo.name}
  category={demo.category}
  theme={demo.slug}
  ctaLabel="Cotizar"
  headerVariant="solid"
  whatsappMessage="Hola AutoPrime, quiero cotizar un servicio automotriz. Mi vehículo es:"
>
  <section class="ap-hero">
    <div class="ap-hero__copy">
      <div class="section-kicker">Taller mecánico · Detailing · Mantención</div>
      <h1>Diagnóstico claro antes de tocar tu auto</h1>
      <p>
        AutoPrime muestra cómo un taller puede captar clientes con una página
        directa: servicios visibles, proceso ordenado, confianza técnica y
        cotización rápida por WhatsApp.
      </p>
      <div class="hero-actions">
        <a class="button" href={whatsappHref} target="_blank" rel="noreferrer">Cotizar por WhatsApp</a>
        <a class="button button--ghost" href="#servicios">Ver servicios</a>
      </div>
      <dl class="ap-quick-grid" aria-label="Datos rápidos de AutoPrime">
        {
          quickStats.map((stat) => (
            <div>
              <dt>{stat.label}</dt>
              <dd>{stat.value}</dd>
            </div>
          ))
        }
      </dl>
    </div>

    <div class="ap-hero__visual">
      <div class="ap-image ap-image--hero" data-fallback={`Reemplazar: ${assets.hero.fileName}`}>
        {
          assets.hero.exists && (
            <img
              src={assets.hero.src}
              alt="Taller mecánico profesional con auto en área de mantención"
              width="900"
              height="980"
              fetchpriority="high"
            />
          )
        }
      </div>
      <div class="ap-gauge" aria-label="Estado de revisión">
        <span>Orden de trabajo</span>
        <strong>Revisión inicial</strong>
        <small>Scanner + checklist visual</small>
      </div>
      <div class="ap-safety-strip" aria-hidden="true"></div>
    </div>
  </section>

  <section class="section ap-services" id="servicios" aria-labelledby="services-title">
    <div class="ap-section-head">
      <div>
        <div class="section-kicker">Servicios principales</div>
        <h2 id="services-title">Mantención, diagnóstico y detalle con foco en cotizar</h2>
      </div>
      <p>
        Fichas técnicas pensadas para que el cliente entienda rápido qué puede
        pedir, qué se revisa y por qué conviene escribir antes de llevar el auto.
      </p>
    </div>

    <div class="ap-service-rack">
      {
        services.map((service) => (
          <article class="ap-service">
            <div class="ap-service__number">{service.number}</div>
            <div class="ap-service__copy">
              <span>{service.tag}</span>
              <h3>{service.title}</h3>
              <p>{service.description}</p>
            </div>
            <div class="ap-service__media ap-image" data-fallback={`Reemplazar: ${service.asset.fileName}`}>
              {
                service.asset.exists && (
                  <img
                    src={service.asset.src}
                    alt={service.alt}
                    width="460"
                    height="320"
                    loading="lazy"
                  />
                )
              }
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <section class="section ap-process" aria-labelledby="process-title">
    <div class="ap-process__intro">
      <div class="section-kicker">Proceso de trabajo</div>
      <h2 id="process-title">Un flujo simple para evitar sorpresas</h2>
      <p>
        La landing no promete reparaciones mágicas: muestra orden, aprobación
        previa y comunicación clara durante el servicio.
      </p>
    </div>
    <ol class="ap-process__rail">
      {
        processSteps.map((step, index) => (
          <li>
            <span>{String(index + 1).padStart(2, '0')}</span>
            <h3>{step.title}</h3>
            <p>{step.text}</p>
          </li>
        ))
      }
    </ol>
  </section>

  <section class="section ap-trust" aria-labelledby="trust-title">
    <div class="ap-trust__panel">
      <div>
        <div class="section-kicker">Confianza operativa</div>
        <h2 id="trust-title">Lo importante se informa antes de ejecutar</h2>
        <p>
          Una buena página de taller debe bajar la incertidumbre: qué se hará,
          cuánto cuesta, qué repuesto se usa y cuándo retirar el vehículo.
        </p>
      </div>
      <div class="ap-checklist" aria-label="Garantías y prácticas de confianza">
        {
          trustItems.map((item) => (
            <span>{item}</span>
          ))
        }
      </div>
    </div>
  </section>

  <section class="section ap-before-after" id="galeria" aria-labelledby="before-after-title">
    <div class="ap-section-head">
      <div>
        <div class="section-kicker">Antes y después</div>
        <h2 id="before-after-title">Detailing visual para vender confianza</h2>
      </div>
      <p>
        Composicion preparada para fotografias reales del proceso. Si aun no hay
        material, el placeholder mantiene una presencia robusta y reemplazable.
      </p>
    </div>
    <div class="ap-comparison">
      <article>
        <span>Antes</span>
        <div class="ap-image" data-fallback={`Reemplazar: ${assets.beforeAfter.fileName}`}>
          {
            assets.beforeAfter.exists && (
              <img
                src={assets.beforeAfter.src}
                alt="Antes del detailing automotriz con pintura y detalles por corregir"
                width="720"
                height="560"
                loading="lazy"
              />
            )
          }
        </div>
      </article>
      <article>
        <span>Despues</span>
        <div class="ap-image" data-fallback={`Reemplazar: ${assets.detailing.fileName}`}>
          {
            assets.detailing.exists && (
              <img
                src={assets.detailing.src}
                alt="Resultado después de detailing exterior automotriz"
                width="720"
                height="560"
                loading="lazy"
              />
            )
          }
        </div>
      </article>
      <div class="ap-comparison__note">
        <strong>Registro opcional</strong>
        <p>Fotos de avance, observaciones y recomendaciones al entregar el auto.</p>
      </div>
    </div>
  </section>

  <section class="ap-promo" aria-labelledby="promo-title">
    <div>
      <div class="section-kicker">Servicio destacado</div>
      <h2 id="promo-title">Mantención preventiva desde $49.990</h2>
      <p>
        Precio referencial de demo. Incluye pauta básica, cambio de aceite sujeto
        a vehículo e inspección visual de puntos críticos.
      </p>
    </div>
    <a class="button" href={whatsappHref} target="_blank" rel="noreferrer">Cotizar mantención</a>
  </section>

  <section class="section ap-vehicles" aria-labelledby="vehicles-title">
    <div class="ap-vehicles__visual ap-image" data-fallback={`Reemplazar: ${assets.workshop.fileName}`}>
      {
        assets.workshop.exists && (
          <img
            src={assets.workshop.src}
            alt="Taller profesional limpio con zona de trabajo automotriz"
            width="760"
            height="640"
            loading="lazy"
          />
        )
      }
    </div>
    <div class="ap-vehicles__copy">
      <div class="section-kicker">Vehículos atendidos</div>
      <h2 id="vehicles-title">Atención para particulares y flotas pequeñas</h2>
      <p>
        Sin afirmar certificaciones oficiales ficticias. La página comunica tipos
        de vehículos, alcance de revisión y coordinación de agenda.
      </p>
      <div class="ap-vehicle-tags">
        {vehicleTypes.map((type) => <span>{type}</span>)}
      </div>
    </div>
  </section>

  <section class="section ap-location" id="contacto" aria-labelledby="location-title">
    <div class="ap-location__copy">
      <div class="section-kicker">Agenda y ubicación</div>
      <h2 id="location-title">Cotiza antes de venir al taller</h2>
      <p>
        Av. Américo Vespucio 1845, Macul. Dirección ficticia para demo comercial.
        Envía marca, modelo, año, kilometraje y motivo de consulta.
      </p>
      <a class="button" href={whatsappHref} target="_blank" rel="noreferrer">Escribir por WhatsApp</a>
    </div>
    <div class="ap-location__cards">
      <article>
        <span>Horario</span>
        <strong>Lun a vie · 09:00 a 19:00</strong>
        <small>Sábado con agenda previa</small>
      </article>
      <article>
        <span>Mensaje sugerido</span>
        <p>Hola AutoPrime, quiero cotizar. Mi vehículo es [marca/modelo/año] y necesito revisar [motivo].</p>
      </article>
      <form class="ap-quote-form" aria-label="Formulario visual de cotización AutoPrime">
        <label>
          Vehículo
          <input type="text" name="vehicle" placeholder="Marca, modelo y año" />
        </label>
        <label>
          Servicio
          <input type="text" name="service" placeholder="Ej: scanner, frenos, detailing" />
        </label>
        <label>
          Teléfono
          <input type="tel" name="phone" placeholder="+56 9 1234 5678" />
        </label>
        <button class="button" type="button">Solicitar cotización</button>
        <small>Formulario visual de demo. El contacto real se simula por WhatsApp.</small>
      </form>
    </div>
  </section>

  <section class="section ap-testimonials" aria-labelledby="testimonials-title">
    <div class="ap-section-head">
      <div>
        <div class="section-kicker">Opiniones</div>
        <h2 id="testimonials-title">Clientes que valoran claridad y puntualidad</h2>
      </div>
    </div>
    <div class="testimonial-grid">
      <TestimonialCard variant="statement" quote="Me explicaron el diagnóstico y aprobaron conmigo antes de cambiar piezas." author="Felipe M." detail="Scanner y mantención" />
      <TestimonialCard quote="Llevé la camioneta por ruido en frenos. Me mostraron el desgaste y la cotización fue clara." author="Carolina R." detail="Frenos delanteros" />
      <TestimonialCard quote="El detailing quedo muy prolijo y enviaron fotos del proceso por WhatsApp." author="Nicolas A." detail="Detailing exterior" />
    </div>
  </section>

  <FAQ
    items={[
      { question: '¿Debo agendar antes de llevar el auto?', answer: 'Sí. Lo ideal es escribir por WhatsApp con marca, modelo, año, kilometraje y motivo de consulta para coordinar recepción.' },
      { question: '¿Hacen scanner?', answer: 'Sí. La demo contempla diagnóstico scanner con lectura de códigos y recomendaciones según síntomas y revisión inicial.' },
      { question: '¿Entregan presupuesto antes de reparar?', answer: 'Sí. La página comunica presupuesto claro y aprobación del cliente antes de ejecutar trabajos adicionales.' },
      { question: '¿Cuánto demora una mantención?', answer: 'Depende del vehículo y disponibilidad de insumos. Una mantención simple puede coordinarse para el mismo día, sujeto a agenda.' },
      { question: '¿Atienden flotas pequeñas?', answer: 'Sí. Se puede coordinar mantención preventiva para pocas unidades, con agenda y registro por vehículo.' },
      { question: '¿Hacen detailing?', answer: 'Sí. Se puede cotizar detailing interior, exterior o combinado según estado del vehículo y resultado esperado.' },
    ]}
  />

  <section class="ap-final-cta" aria-labelledby="final-title">
    <div>
      <div class="section-kicker">Cotización rápida</div>
      <h2 id="final-title">Cotiza tu servicio automotriz</h2>
      <p>
        Una landing así ayuda a un taller a mostrar orden, evidencia y contacto
        directo sin implementar reservas ni backend.
      </p>
    </div>
    <a class="button" href={whatsappHref} target="_blank" rel="noreferrer">Cotizar por WhatsApp</a>
  </section>
</DemoLayout>
