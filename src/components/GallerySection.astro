---
type GalleryItem = {
  title: string;
  description?: string;
};

type Props = {
  title?: string;
  eyebrow?: string;
  items: GalleryItem[];
};

const {
  title = 'Galería',
  eyebrow = 'Vista preliminar',
  items,
} = Astro.props;
---

<section class="gallery-section" id="galeria" aria-labelledby="gallery-title">
  <div class="section-kicker">{eyebrow}</div>
  <h2 id="gallery-title">{title}</h2>
  <div class="gallery-grid">
    {
      items.map((item, index) => (
        <article class="gallery-tile">
          <div class="gallery-tile__media" aria-hidden="true">{String(index + 1).padStart(2, '0')}</div>
          <h3>{item.title}</h3>
          {item.description && <p>{item.description}</p>}
        </article>
      ))
    }
  </div>
</section>
