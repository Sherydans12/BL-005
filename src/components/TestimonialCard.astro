---
type Props = {
  quote: string;
  author: string;
  detail?: string;
  variant?: 'default' | 'compact' | 'statement';
};

const { quote, author, detail, variant = 'default' } = Astro.props;
---

<article class={`testimonial-card testimonial-card--${variant}`}>
  <p>“{quote}”</p>
  <footer>
    <strong>{author}</strong>
    {detail && <span>{detail}</span>}
  </footer>
</article>
