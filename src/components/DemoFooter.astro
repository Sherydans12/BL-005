---
type Props = {
  businessName: string;
  category: string;
};

const { businessName, category } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="demo-footer">
  <div>
    <strong>{businessName}</strong>
    <p>{category} · Demo creada para el portafolio de BaseLogic.</p>
  </div>
  <a href="/demos">Ver otras demos</a>
  <small>© {year} BaseLogic demo</small>
</footer>
